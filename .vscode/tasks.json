{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Run Backend (FastAPI)",
      "type": "shell",
      "command": "cd backend; C:/Users/user/AppData/Local/Programs/Python/Python313/python.exe main.py",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Frontend (Next.js)",
      "type": "shell",
      "command": "cd frontend; npm run dev",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Run Project (Full Stack)",
      "dependsOn": ["Run Backend (FastAPI)", "Run Frontend (Next.js)"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
